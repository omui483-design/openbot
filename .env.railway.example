# Railway Environment Variables Template
# Copy these to your Railway project's environment variables

# Gateway Configuration
PORT=18789
OPENCLAW_GATEWAY_PORT=$PORT
OPENCLAW_GATEWAY_BIND=0.0.0.0

# Node Environment
NODE_ENV=production

# OpenClaw Configuration
OPENCLAW_STATE_DIR=/app/data
OPENCLAW_CONFIG_PATH=/app/data/openclaw.json

# AI Model Configuration (Add your API keys)
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# GOOGLE_API_KEY=your_key_here

# Gateway Token (Generate a secure random token)
# OPENCLAW_GATEWAY_TOKEN=your_secure_token_here

# Optional: Logging
OPENCLAW_LOG_LEVEL=info

# Optional: Channels (if using)
# TELEGRAM_BOT_TOKEN=your_token_here
# DISCORD_BOT_TOKEN=your_token_here
# WHATSAPP_SESSION_PATH=/app/data/whatsapp
