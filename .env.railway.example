# Railway Environment Variables Template
# Copy these to your Railway project's environment variables

# Gateway Configuration
PORT=18789
OPENCLAW_GATEWAY_PORT=$PORT
OPENCLAW_GATEWAY_BIND=0.0.0.0

# Node Environment
NODE_ENV=production

# OpenClaw Configuration
OPENCLAW_STATE_DIR=/app/data
OPENCLAW_CONFIG_PATH=/app/data/openclaw.json

# ===== AI Model Configuration =====
# You can add multiple API keys and switch between models anytime
# OpenClaw will auto-detect available models

# Google Gemini (Recommended for free tier)
GOOGLE_API_KEY=your_gemini_api_key
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key
# Models: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-1.5-flash

# Anthropic Claude (Best quality)
ANTHROPIC_API_KEY=sk-ant-your_claude_key
# Models: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229

# OpenAI (GPT models)
OPENAI_API_KEY=sk-your_openai_key
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo

# Moonshot AI / Kimi (Chinese, long context)
MOONSHOT_API_KEY=your_kimi_api_key
# Models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k

# DeepSeek (Cheap and good)
DEEPSEEK_API_KEY=your_deepseek_key
# Models: deepseek-chat, deepseek-coder

# Groq (Super fast inference)
GROQ_API_KEY=your_groq_key
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768

# xAI Grok (if you have access)
XAI_API_KEY=your_xai_key
# Models: grok-beta

# Default model to use (optional, can change in dashboard)
OPENCLAW_DEFAULT_MODEL=gemini-2.0-flash-exp

# Gateway Token (Generate a secure random token)
# OPENCLAW_GATEWAY_TOKEN=your_secure_token_here

# Optional: Logging
OPENCLAW_LOG_LEVEL=info

# Optional: Channels
# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username

# WhatsApp (Requires QR scan - see RAILWAY_DEPLOY.md)
# WHATSAPP_SESSION_PATH=/app/data/whatsapp
# Note: WhatsApp on Railway requires volume + QR scan from logs
